{
  "expo": {
    "name": "Geo Conquest",
    "slug": "tomtom-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/newicon.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tomtomtracker.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/newicon.jpeg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tomtomtracker.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-task-manager",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "02e208d6-5ea8-4855-ba8c-6dd204e9b382"
      }
    }
  }
}