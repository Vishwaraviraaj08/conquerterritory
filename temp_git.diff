+        alignItems: 'center',
+        justifyContent: 'center',
+        zIndex: 10,
+    },
+    logoContainer: {
+        shadowColor: '#5B63D3',
+        shadowOffset: { width: 0, height: 0 },
+        shadowOpacity: 0.8,
+        shadowRadius: 40,
+        elevation: 25,
+    },
+    iconCircle: {
+        width: 140,
+        height: 140,
+        justifyContent: 'center',
+        alignItems: 'center',
+        // Removed borders as SVG handles the shape
+    },
+    title: {
+        fontSize: 34, // Adjusted size
+        fontWeight: '900',
+        color: '#fff',
+        textAlign: 'center',
+        textShadowColor: 'rgba(138, 43, 226, 0.5)',
+        textShadowOffset: { width: 0, height: 2 },
+        textShadowRadius: 10,
+    },
+    separator: {
+        width: 60,
+        height: 3,
+        backgroundColor: '#FFD700', // Gold separator
+        marginTop: 10,
+        marginBottom: 10,
+        borderRadius: 2,
+    },
+    subtitle: {
+        fontSize: 13,
+        fontWeight: '500',
+        color: '#a0a3bd',
+        textAlign: 'center',
+        fontStyle: 'italic',
+        maxWidth: '85%',
+        marginTop: 5,
+    }
+});
